# Copia este archivo como .env y llena los valores.
# El .env NUNCA se sube al repo (ya está en .gitignore).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_BUCKET=comparte-tu-gato-museo

# Prefijo dentro del bucket donde quedan las fotos aprobadas
S3_PREFIJO=aprobadas/

# Carpeta que lee TouchDesigner, p. ej. C:\museo\fotos_td
# (Si se omite, usa la carpeta fotos_td dentro de agente-local)
CARPETA_DESTINO=

# Cada cuántos segundos revisa el bucket
INTERVALO_SEG=10

# Tamaño del buffer circular (gato_001..gato_999)
MAX_FOTOS=999
